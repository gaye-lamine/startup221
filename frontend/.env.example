# ─── Startup221 Frontend — Variables d'environnement ─────────────────────────
# Copie ce fichier en `.env.local` pour le développement local.
# Sur Netlify, configure ces variables dans :
# Site Settings → Environment Variables

# URL de l'API FastAPI backend (production)
# Exemple : https://startup221-api.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:8000
